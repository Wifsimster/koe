    "conventional-changelog-conventionalcommits": "^8.0.0",
    "prettier": "^3.3.0",
    "semantic-release": "^24.2.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.8.1"
  }
}
