{
  "name": "koe",
  "version": "0.1.0",
  "private": true,
  "description": "Embeddable support widget for SaaS apps — bug reports, feature requests & live chat in one unified experience",
  "license": "MIT",
  "author": "wifsimster",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
