{
  "name": "@koe/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/bin/serve.ts",
    "build": "tsup",
    "start": "node dist/serve.js",
    "migrate": "node dist/migrate.js",
    "bootstrap": "node dist/bootstrap.js",
    "test": "node --import tsx --test src/lib/*.test.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@koe/shared": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.10",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.28.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  }
}
