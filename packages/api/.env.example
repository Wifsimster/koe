DATABASE_URL=postgres://postgres:postgres@localhost:5432/koe
PORT=8787

# -- Secret-at-rest encryption -----------------------------------------
#
# When set, `projects.identity_secret` and
# `project_identity_secrets.secret` are envelope-encrypted with
# AES-256-GCM before persistence. Leaving these unset is acceptable
# for dev — the API logs a warning on first use and falls back to
# storing plaintext.
#
# Format:
#   KOE_SECRET_KEYS=kid1:<base64-32-bytes>[,kid2:<base64-32-bytes>]
#   KOE_SECRET_ACTIVE_KID=kid1
#
# Generate a key:
#   openssl rand -base64 32
#
# Rotation: add a new kid, set it as active, re-encrypt existing rows
# (see the future `rotate-secrets` CLI), then drop the retired kid.
# Keeping the retired kid in the set until rotation completes lets
# old blobs decrypt without downtime.
#
#KOE_SECRET_KEYS=v1:REPLACE_ME_WITH_BASE64_32_BYTES
#KOE_SECRET_ACTIVE_KID=v1

# -- Redis --------------------------------------------------------------
#
# When set, the widget rate limiter and the v2 identity-token nonce
# cache use Redis instead of in-memory state. Set this the moment you
# run more than one API replica — otherwise the rate limiter buckets
# and the nonce cache are per-pod, which breaks the abuse controls
# and replay protection we rely on.
#
# Accepts the standard `redis://…` URL form, including `redis+tls://`
# or `rediss://` for TLS, and username/password in the authority part.
# ioredis handles reconnects transparently.
#
#REDIS_URL=redis://localhost:6379

# Admin JSON API mount. Leave unset to boot without the admin surface —
# the safe default so a fresh deploy never exposes admin routes.
#
#   dev-session  → bearer-token auth, mint tokens with the
#                  `admin-session` CLI. Refused in production.
#   oidc         → provider-agnostic OIDC login. Requires the vars
#                  below to be set.
#ADMIN_AUTH_MODE=oidc

# Origin the dashboard is served from, for admin API CORS. Same-origin
# deployments (dashboard at `/admin/*` on this API) can leave it unset.
#ADMIN_DASHBOARD_ORIGIN=http://localhost:5173

# -- OIDC ---------------------------------------------------------------

# Issuer base URL. Any spec-compliant provider works:
#   Auth0         https://tenant.eu.auth0.com
#   Clerk         https://<your-app>.clerk.accounts.dev
#   WorkOS        https://api.workos.com (with dynamic OIDC)
#   Keycloak      https://auth.example.com/realms/koe
#   Google        https://accounts.google.com
#OIDC_ISSUER_URL=https://tenant.eu.auth0.com

# Client credentials from your provider's dashboard.
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=

# Where the provider redirects after the user authenticates. Must
# match what's registered with the provider.
#OIDC_REDIRECT_URI=https://koe.example.com/v1/admin/auth/callback

# Absolute URL of the dashboard. Used as the post-login redirect and
# as the base for sanitizing `?redirect_to=` query params.
#OIDC_DASHBOARD_URL=https://koe.example.com/admin/

# Space-separated scopes. `openid email profile` is the default.
# Override if your provider needs more (e.g. Azure AD may require
# `openid email profile User.Read`).
#OIDC_SCOPES=openid email profile

# Secret used to sign the transient state cookie during the OIDC
# dance. 32+ random bytes, base64 or hex. Rotatable.
#OIDC_COOKIE_SECRET=replace-me-with-a-long-random-string

# -- Session cookie -----------------------------------------------------

# Name of the long-lived session cookie set after a successful OIDC
# callback. Rename to avoid collisions when multiple Koe deployments
# share a parent domain.
#ADMIN_SESSION_COOKIE=koe_admin

# Session TTL in days (default 30). Renewed on each successful
# `/me` call would be a future improvement — today the cookie
# expiration matches the DB row's `expires_at`.
#ADMIN_SESSION_TTL_DAYS=30

# `Secure` flag on cookies. Set `false` only for local HTTP dev.
#ADMIN_COOKIES_SECURE=true
