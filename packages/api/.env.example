DATABASE_URL=postgres://postgres:postgres@localhost:5432/koe
PORT=8787

# Admin JSON API mount. Leave unset to boot without the admin surface —
# the safe default so a fresh deploy never exposes admin routes.
#
#   dev-session  → bearer-token auth, mint tokens with the
#                  `admin-session` CLI. Refused in production.
#   oidc         → real provider integration (ships in a later MR).
#ADMIN_AUTH_MODE=dev-session

# Origin the dashboard is served from, for admin API CORS. Same-origin
# deployments (dashboard at `/admin/*` on this API) can leave it unset.
#ADMIN_DASHBOARD_ORIGIN=http://localhost:5173

# Placeholders for the OIDC integration — not wired yet.
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:8787
