DATABASE_URL=postgres://postgres:postgres@localhost:5432/koe
PORT=8787

# -- Secret-at-rest encryption -----------------------------------------
#
# When set, `projects.identity_secret` and
# `project_identity_secrets.secret` are envelope-encrypted with
# AES-256-GCM before persistence. Leaving these unset is acceptable
# for dev — the API logs a warning on first use and falls back to
# storing plaintext.
#
# Format:
#   KOE_SECRET_KEYS=kid1:<base64-32-bytes>[,kid2:<base64-32-bytes>]
#   KOE_SECRET_ACTIVE_KID=kid1
#
# Generate a key:
#   openssl rand -base64 32
#
#KOE_SECRET_KEYS=v1:REPLACE_ME_WITH_BASE64_32_BYTES
#KOE_SECRET_ACTIVE_KID=v1

# -- Redis --------------------------------------------------------------
#
# When set, the widget rate limiter and the v2 identity-token nonce
# cache use Redis instead of in-memory state. Set this the moment you
# run more than one API replica.
#
#REDIS_URL=redis://localhost:6379

# -- Admin auth ---------------------------------------------------------
#
# Koe is a single-admin product. Credentials live in env vars; the
# session is a signed cookie. Set ALL THREE to enable the admin API
# (and the dashboard if ENABLE_DASHBOARD=true). Leave them all unset
# to boot without the admin surface — the safe default for a fresh
# deploy that hasn't been configured yet.
#
# Generate the password hash interactively (NEVER pass the password on
# the command line — it lands in shell history and `ps`):
#   docker compose run --rm api hash-password
#
# Generate the session secret:
#   openssl rand -hex 32
#
# Rotating the password: re-run `hash-password`, replace the hash,
# restart the server. This also invalidates existing sessions. Forgot
# the password? Same flow — just pick a new one.
#
# Rotating ADMIN_SESSION_SECRET invalidates every outstanding session
# cookie on the next request — the "kick myself out" button.
#
#ADMIN_EMAIL=
#ADMIN_PASSWORD_HASH=
#ADMIN_SESSION_SECRET=

# -- Session cookie -----------------------------------------------------

# Session TTL in days (default 7). Keep it short — a stolen cookie is
# valid until expiry, and there's no server-side revocation short of
# rotating ADMIN_SESSION_SECRET.
#ADMIN_SESSION_TTL_DAYS=7

# `Secure` flag on cookies. Set `false` only for local HTTP dev.
#ADMIN_COOKIES_SECURE=true

# -- Email notifications (Resend) --------------------------------------
#
# When set, every new bug or feature submission from the widget triggers
# a fire-and-forget email to the project owner. Leave RESEND_API_KEY
# unset to disable email notifications entirely (the widget keeps
# working unchanged — Resend errors never block submission).
#
# Get an API key: https://resend.com — then verify your sending
# domain so RESEND_FROM_EMAIL is accepted.
#
#RESEND_API_KEY=re_REPLACE_ME
#RESEND_FROM_EMAIL=Koe <notifications@yourdomain.com>

# Recipient resolution: NOTIFY_OWNER_EMAIL > ADMIN_EMAIL > skip.
# Single-admin product today; the resolver moves to a per-project
# owner lookup once project_members exists.
#NOTIFY_OWNER_EMAIL=

# Optional: public base URL of the dashboard. When set, every
# notification email contains a link to /admin/tickets/:id so a
# tap from the inbox lands you on the right ticket.
#DASHBOARD_PUBLIC_URL=https://koe.yourdomain.com

# Once configured, verify the wiring without waiting for a real
# submission. From an admin session:
#   GET  /v1/admin/notifications/email
#       → reports which env vars are set and the resolved recipient.
#   POST /v1/admin/notifications/email/test  (body optional)
#       → sends one test email; pass `{ "to": "you@example.com" }`
#         to override the recipient.
