DATABASE_URL=postgres://postgres:postgres@localhost:5432/koe
PORT=8787

# -- Secret-at-rest encryption -----------------------------------------
#
# When set, `projects.identity_secret` and
# `project_identity_secrets.secret` are envelope-encrypted with
# AES-256-GCM before persistence. Leaving these unset is acceptable
# for dev — the API logs a warning on first use and falls back to
# storing plaintext.
#
# Format:
#   KOE_SECRET_KEYS=kid1:<base64-32-bytes>[,kid2:<base64-32-bytes>]
#   KOE_SECRET_ACTIVE_KID=kid1
#
# Generate a key:
#   openssl rand -base64 32
#
# Rotation: add a new kid, set it as active, re-encrypt existing rows
# (see the future `rotate-secrets` CLI), then drop the retired kid.
# Keeping the retired kid in the set until rotation completes lets
# old blobs decrypt without downtime.
#
#KOE_SECRET_KEYS=v1:REPLACE_ME_WITH_BASE64_32_BYTES
#KOE_SECRET_ACTIVE_KID=v1

# Admin JSON API mount. Leave unset to boot without the admin surface —
# the safe default so a fresh deploy never exposes admin routes.
#
#   dev-session  → bearer-token auth, mint tokens with the
#                  `admin-session` CLI. Refused in production.
#   oidc         → real provider integration (ships in a later MR).
#ADMIN_AUTH_MODE=dev-session

# Origin the dashboard is served from, for admin API CORS. Same-origin
# deployments (dashboard at `/admin/*` on this API) can leave it unset.
#ADMIN_DASHBOARD_ORIGIN=http://localhost:5173

# Placeholders for the OIDC integration — not wired yet.
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:8787
