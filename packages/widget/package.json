{
  "name": "@wifsimster/koe",
  "version": "0.1.0",
  "description": "Embeddable support widget for SaaS apps — bug reports, feature requests & live chat.",
  "license": "MIT",
  "author": "wifsimster",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wifsimster/koe.git",
    "directory": "packages/widget"
  },
  "homepage": "https://github.com/Wifsimster/koe/tree/main/packages/widget#readme",
  "bugs": {
    "url": "https://github.com/Wifsimster/koe/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./standalone": "./dist/koe.iife.js"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:lib && pnpm build:standalone",
    "build:lib": "tsc --noEmit && BUILD_TARGET=lib vite build",
    "build:standalone": "BUILD_TARGET=standalone vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@koe/shared": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0"
  }
}
