# Copy to `.env` before running `docker compose up`.
# `docker compose` reads this file automatically from the project root.

# --- Which image to pull ------------------------------------------------
# `edge` tracks `main`; pin to a semver tag (e.g. `0.1.0`) for production.
KOE_API_TAG=edge

# --- Host port mapping --------------------------------------------------
# The container always listens on 8787 internally. Change this to expose
# it on a different host port.
KOE_API_PORT=8787

# --- Postgres credentials -----------------------------------------------
# These are ONLY used inside the compose network. Change them before
# pointing anything real at this stack.
POSTGRES_DB=koe
POSTGRES_USER=koe
POSTGRES_PASSWORD=change-me

# --- Migration behaviour ------------------------------------------------
# When `true` (default), the API applies pending migrations on boot.
# Set to `false` if you run multiple API replicas and prefer to run
# `docker compose run --rm api migrate` once as a separate deploy step.
MIGRATE_ON_START=true

# --- Admin dashboard ----------------------------------------------------
# Serves the Koe admin dashboard at `/admin/`. Enabled by default so a
# fresh `docker compose up` exposes the UI immediately on
# http://localhost:8787/admin/.
#
# The dashboard has no built-in auth yet (better-auth integration is
# pending). Set this to `false` if you expose the API publicly without
# putting your own auth proxy in front of `/admin/*`.
ENABLE_DASHBOARD=true
