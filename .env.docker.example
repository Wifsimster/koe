# Copy to `.env` before running `docker compose up`.
# `docker compose` reads this file automatically from the project root.

# --- Which image to pull ------------------------------------------------
# `edge` tracks `main`; pin to a semver tag (e.g. `0.1.0`) for production.
KOE_SERVER_TAG=edge

# --- Host port mapping --------------------------------------------------
# The container always listens on 8787 internally. Change this to expose
# it on a different host port.
KOE_SERVER_PORT=8787

# --- Postgres credentials -----------------------------------------------
# These are ONLY used inside the compose network, but `docker compose`
# exposes them as env vars on the containers, so treat `POSTGRES_PASSWORD`
# as a real secret and REPLACE it before the first `docker compose up`.
# Generate one with e.g. `openssl rand -hex 32`.
POSTGRES_DB=koe
POSTGRES_USER=koe
POSTGRES_PASSWORD=REPLACE_ME_WITH_A_LONG_RANDOM_SECRET

# --- Migration behaviour ------------------------------------------------
# When `true` (default), the API applies pending migrations on boot.
# Set to `false` if you run multiple API replicas and prefer to run
# `docker compose run --rm api migrate` once as a separate deploy step.
MIGRATE_ON_START=true

# --- Admin credentials --------------------------------------------------
# Koe is a single-admin product. Set ALL THREE vars below to enable the
# admin dashboard. The server refuses to boot if any still contains the
# REPLACE_ME sentinel, so an operator who skips this step gets a loud
# error instead of a silently-broken login.
#
# 1. Set ADMIN_EMAIL to your real email.
#
# 2. Generate the password hash interactively (NEVER pass the password
#    on the command line — it lands in shell history and `ps`):
#      docker compose run --rm api hash-password
#    Paste the printed hash into ADMIN_PASSWORD_HASH below, wrapped in
#    single quotes (the `$argon2id$…` segments would otherwise be
#    interpreted by the shell).
#
# 3. Generate the session secret:
#      openssl rand -hex 32
#
# Rotating the password: repeat step 2 with a new password, replace the
# hash, then `docker compose up -d` to restart. This also invalidates
# existing sessions. Forgot the password? Same flow — just pick a new
# one.
#
# Rotating ADMIN_SESSION_SECRET invalidates every outstanding session
# cookie on the next request — the "kick myself out" button.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# --- Admin dashboard ----------------------------------------------------
# Serves the Koe admin dashboard at `/admin/`. On by default — the
# session cookie + ADMIN_PASSWORD_HASH gate every admin call. Flip to
# `false` to keep the UI off entirely (the JSON API still serves under
# /v1/admin/* if ADMIN_* vars are configured).
ENABLE_DASHBOARD=true

# --- Email notifications (Resend) ---------------------------------------
# When RESEND_API_KEY is set, every new bug/feature submission triggers
# a fire-and-forget email to the project owner. Leave unset to disable.
# RESEND_FROM_EMAIL must be a domain you've verified in Resend.
# Recipient is NOTIFY_OWNER_EMAIL, falling back to ADMIN_EMAIL.
#RESEND_API_KEY=
#RESEND_FROM_EMAIL=Koe <notifications@yourdomain.com>
#NOTIFY_OWNER_EMAIL=
#DASHBOARD_PUBLIC_URL=https://koe.yourdomain.com
